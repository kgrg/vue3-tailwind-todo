{
  "name": "taskflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @taskflow/web dev",
    "dev:api": "pnpm --filter @taskflow/api dev",
    "dev:storybook": "pnpm --filter @taskflow/ui storybook",
    "build:web": "pnpm --filter @taskflow/web build",
    "build:api": "pnpm --filter @taskflow/api build",
    "build:storybook": "pnpm --filter @taskflow/ui build-storybook",
    "build:ui": "pnpm --filter @taskflow/ui build"
  },
  "devDependencies": {
    "@voidzero-dev/vite-plus-core": "latest",
    "vite-plus": "latest"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@9.12.3+sha1.4fb96925d434c491285182acf29803bb9aa2e6e5"
}
